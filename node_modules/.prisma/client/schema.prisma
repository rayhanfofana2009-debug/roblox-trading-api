generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LicenseStatus {
  ACTIVE
  LOCKED_IN_TRADE
  REVOKED
}

enum LicenseOrigin {
  PURCHASE
  TRADE
}

enum TradeStatus {
  PENDING
  COMPLETED
  CANCELLED
  EXPIRED
}

enum TradeSide {
  INITIATOR
  COUNTERPARTY
}

model LicenseType {
  id              String           @id @default(uuid()) @db.Uuid
  displayName     String
  tradable        Boolean          @default(true)
  stackable       Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  purchaseSources PurchaseSource[]
  purchases       Purchase[]
  licenses        License[]
}

model PurchaseSource {
  id            String      @id @default(uuid()) @db.Uuid
  universeId    BigInt
  gamepassId    BigInt
  licenseTypeId String      @db.Uuid
  createdAt     DateTime    @default(now())
  licenseType   LicenseType @relation(fields: [licenseTypeId], references: [id], onDelete: Restrict)

  @@unique([universeId, gamepassId])
  @@index([licenseTypeId])
}

model Purchase {
  id              String      @id @default(uuid()) @db.Uuid
  robloxReceiptId String      @unique
  buyerUserId     BigInt
  licenseTypeId   String      @db.Uuid
  createdAt       DateTime    @default(now())
  licenseType     LicenseType @relation(fields: [licenseTypeId], references: [id], onDelete: Restrict)
  license         License?

  @@unique([buyerUserId, licenseTypeId])
  @@index([licenseTypeId])
}

model License {
  id                    String           @id @default(uuid()) @db.Uuid
  licenseTypeId         String           @db.Uuid
  ownerUserId           BigInt
  status                LicenseStatus    @default(ACTIVE)
  origin                LicenseOrigin
  createdFromPurchaseId String?          @unique @db.Uuid
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  licenseType           LicenseType      @relation(fields: [licenseTypeId], references: [id], onDelete: Restrict)
  createdFromPurchase   Purchase?        @relation(fields: [createdFromPurchaseId], references: [id], onDelete: SetNull)
  sentTradeItems        TradeItem[]      @relation("TradeItemFromLicense")
  ownershipEvents       OwnershipEvent[]

  @@index([ownerUserId])
  @@index([licenseTypeId, ownerUserId])
  @@index([status])
}

model Trade {
  id                 String      @id @default(uuid()) @db.Uuid
  initiatorUserId    BigInt
  counterpartyUserId BigInt
  status             TradeStatus @default(PENDING)
  createdAt          DateTime    @default(now())
  completedAt        DateTime?
  items              TradeItem[]
}

model TradeItem {
  id         String    @id @default(uuid()) @db.Uuid
  tradeId    String    @db.Uuid
  side       TradeSide
  licenseId  String    @db.Uuid
  fromUserId BigInt
  createdAt  DateTime  @default(now())
  trade      Trade     @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  license    License   @relation("TradeItemFromLicense", fields: [licenseId], references: [id], onDelete: Restrict)

  @@unique([tradeId, licenseId])
  @@index([licenseId])
}

model OwnershipEvent {
  id         String   @id @default(uuid()) @db.Uuid
  licenseId  String   @db.Uuid
  fromUserId BigInt?
  toUserId   BigInt
  reason     String
  purchaseId String?  @db.Uuid
  tradeId    String?  @db.Uuid
  createdAt  DateTime @default(now())
  license    License  @relation(fields: [licenseId], references: [id], onDelete: Restrict)

  @@index([licenseId, createdAt])
  @@index([toUserId, createdAt])
}
